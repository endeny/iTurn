{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@source/sdk": [
        "src/source-sdk.d.ts"
      ]
    },
    "types": [
      "bun-types",
      "node"
    ]
  },
  "include": [
    "src",
    "web/src"
  ]
}